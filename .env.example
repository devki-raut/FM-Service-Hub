APP_NAME="FM Service Hub RAG Bot"
ENVIRONMENT=local

LLM_PROVIDER=azure_foundry
EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768

AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=
#AZURE_FOUNDRY_API_VERSION=2024-05-01-preview
AZURE_FOUNDRY_CHAT_MODEL=mistral-medium-3-5
AZURE_FOUNDRY_EMBEDDING_MODEL=

MISTRAL_API_KEY=
MISTRAL_CHAT_MODEL=mistral-medium-latest
MISTRAL_EMBEDDING_MODEL=mistral-embed

AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=fm-service-hub-docs-v3
AZURE_SEARCH_MIN_SCORE=0.0

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=rag-source-documents

AZURE_AD_TENANT_ID=
AZURE_AD_AUDIENCE=
AUTH_REQUIRED=false

BOT_APP_ID=
BOT_APP_PASSWORD=

CHUNK_SIZE=1200
CHUNK_OVERLAP=180
TOP_K=5
FASTEMBED_CACHE_DIR=.fastembed_cache

EXCEL_SOURCE_PATH="FM SERVICE HUB"

